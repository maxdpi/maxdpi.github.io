# The Studio reads project/dataset from sanity.config.ts / sanity.cli.ts,
# so no env file is required for local dev.
#
# This file documents the public (non-secret) project values used by the
# front-end. Do NOT put API tokens here for the browser front-end — it only
# reads published content from the public dataset.
SANITY_PROJECT_ID=aiajifvh
SANITY_DATASET=production
